# API base URL. The default in code is http://localhost:3000, so you only
# need a real .env if your server runs elsewhere.
VITE_API_URL=http://localhost:3000

# Auth0 — copy to .env.local and fill from the Auth0 dashboard
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=xxxxxxxx
VITE_AUTH0_AUDIENCE=https://mech-assemble-wiki/api
