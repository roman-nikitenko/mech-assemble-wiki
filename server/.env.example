# Copy to .env and adjust for your local Postgres.
# Postgres.app on macOS: user = your macOS username, no password.
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/mech_assemble_wiki?schema=public"

# Auth0 — merge these into your existing .env
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://mech-assemble-wiki/api
ADMIN_LOGIN=admin
# generate with: npm run admin:hash -- "your password"
ADMIN_PASSWORD_HASH=salt:hash
ADMIN_JWT_SECRET=any-long-random-string
