// Prisma schema for the Mech Assemble wiki — 19 tables + 2 enums (MechRank, SkillNodeType).
// Source of truth for the domain model: CLAUDE.md at the repo root.
//
// Conventions used throughout:
// - Model names are PascalCase, mapped to snake_case table names with @@map.
// - Field names are camelCase, mapped to snake_case columns with @map.
// - Every primary key is a UUID (project convention).
// - Flexible stat blocks are jsonb (Json type) — their shape varies per mech.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum MechRank {
  Standard
  S
}

enum SkillNodeType {
  Normal
  Premium
  Core
}

// A build's publication state, WordPress-style. Draft = private working copy
// (created by the editor); Published = visible in the public feed; Unposted =
// pulled from the feed but kept (its hearts + share link survive a republish).
enum BuildStatus {
  Draft
  Published
  Unposted
}

// ---------- The hub ----------

model Mech {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  epithet      String? // subtitle, e.g. "Shadow Hunter"
  // Element type is a CATALOG ROW now, not an enum: the admin manages types
  // (name + icon) in the UI. Nullable by design — the catalog starts empty
  // and real data gets assigned as it's entered. onDelete: Restrict is the
  // third delete flavor in this schema: a type that's in use cannot be
  // deleted (contrast: mech children Cascade; pilots SetNull).
  typeId String? @map("type_id") @db.Uuid
  type   Type?   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  rank         MechRank
  // Deliberately a plain string like "ATK +10%" — NOT structured fields.
  // Explicit product decision (see CLAUDE.md); do not normalize.
  specialBonus String?  @map("special_bonus")
  lore         String?
  // Up to 7 rank-up preview lines. POSITIONAL, unlike the weapon field:
  // index = rank position, so interior blanks ("" entries) are meaningful
  // and preserved; only trailing blanks are trimmed by the API.
  rankUpPreview String[] @map("rank_up_preview")
  // Path to the mech's image under /uploads (e.g. "/uploads/abc.png").
  // We store the POINTER, not the image: databases are bad at large binary
  // blobs; filesystems/CDNs are good at them.
  imageUrl String? @map("image_url")
  // Second art slot, same Image+Icon pair weapons and accessories have.
  iconUrl String? @map("icon_url")
  // Third art slot: the art shown inside this mech's skill CARDS
  // (build editor / game-style rank-up cards).
  cardSkillIconUrl String? @map("card_skill_icon_url")

  // S-tier-only systems below are optional/empty for Standard mechs;
  // the frontend decides what to show based on `rank`.
  skills          MechSkill[]
  traits          MechTrait[]
  awakeningLevels AwakeningLevel[]
  weapon          Weapon?
  accessory       Accessory?
  skins           Skin[]
  helpers         Helper[]
  pilot           Pilot?
  skillNodes      SkillNode[]

  @@map("mechs")
}

// ---------- Pilots (S-tier only, exclusive 1:1 with a mech) ----------

model Pilot {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @unique
  unlockBoost       String?  @map("unlock_boost")
  relationshipBonus String?  @map("relationship_bonus")
  // Up to 4 per-level bonus strings (Lv.1-4). Postgres text[]; "max 4" is an
  // app-level rule enforced by the API, same philosophy as awakening nodes.
  bonusPerLevel     String[] @map("bonus_per_level")
  iconUrl           String?  @map("icon_url")
  backgroundUrl     String?  @map("background_url")
  // The 1:1 link: nullable = a pilot may be unassigned; @unique = a mech can
  // have at most one pilot. onDelete: SetNull — deleting a MECH must not
  // delete the pilot, just vacate the cockpit. Deliberate contrast with the
  // Cascade used on mech children: the pilot is a standalone entity, not a
  // part of the mech. "S-tier only" is enforced by the API, not the DB.
  mechId String? @unique @map("mech_id") @db.Uuid
  mech   Mech?   @relation(fields: [mechId], references: [id], onDelete: SetNull)
  // Either/or with mechId (app-enforced): a pilot sits in a mech OR fronts
  // a weapon, never both. Same SetNull reasoning — pilots are standalone.
  weaponId String? @unique @map("weapon_id") @db.Uuid
  weapon   Weapon? @relation(fields: [weaponId], references: [id], onDelete: SetNull)

  @@map("pilots")
}

model WeaponSkin {
  id       String   @id @default(uuid()) @db.Uuid
  weaponId String   @map("weapon_id") @db.Uuid
  name     String
  // Up to 5 star-bonus strings (★1-5) — deliberately a SEPARATE shape from mech skins
  // (skins + skin_stars): the two skin systems will diverge (future SS skins).
  bonuses  String[]
  imageUrl String?  @map("image_url")

  weapon Weapon @relation(fields: [weaponId], references: [id], onDelete: Cascade)

  @@map("weapon_skins")
}

// ---------- Skill tree (generic; weapons this cycle, mechs later) ----------

// Replaces the old weapon_upgrades system (dormant since Cycle I; cleanup is
// a future cycle). Dual-owner since Cycle J.
model SkillNode {
  id String @id @default(uuid()) @db.Uuid
  // Dual-owner since Cycle J (like helpers): EXACTLY ONE of weaponId/mechId
  // is set — enforced by the writers (each router sets only its own owner),
  // not by the DB.
  weaponId String? @map("weapon_id") @db.Uuid
  mechId   String? @map("mech_id") @db.Uuid
  // Any-depth inheritance: parent points at a node in the SAME tree.
  // Named self-relation, like the older upgrade trees.
  parentId String? @map("parent_id") @db.Uuid
  // Nullable by design: Core skills have no name, only a description.
  name            String?
  description     String?
  // "Available from weapon level X" — 1..10, app-enforced.
  appearanceLevel Int           @default(1) @map("appearance_level")
  type            SkillNodeType @default(Normal)
  // Sibling position; written by the drag-and-drop editor.
  sortOrder Int @default(0) @map("sort_order")
  // Normal-only: when true, this skill may be added to a build multiple
  // times, each copy taking one of the 8 shared slots. Forced false for
  // Premium/Core (they are never repeatable).
  repeatable Boolean @default(false)

  weapon   Weapon?     @relation(fields: [weaponId], references: [id], onDelete: Cascade)
  mech     Mech?       @relation(fields: [mechId], references: [id], onDelete: Cascade)
  parent   SkillNode?  @relation("SkillNodeTree", fields: [parentId], references: [id])
  children SkillNode[] @relation("SkillNodeTree")

  @@map("skill_nodes")
}

// ---------- Types (element catalog: Fire, Thunder, ... with icons) ----------

model Type {
  id      String  @id @default(uuid()) @db.Uuid
  name    String  @unique
  iconUrl String? @map("icon_url")

  mechs   Mech[]
  weapons Weapon[]

  @@map("types")
}

// ---------- Skills + upgrade tree ----------

model MechSkill {
  id          String  @id @default(uuid()) @db.Uuid
  mechId      String  @map("mech_id") @db.Uuid
  name        String
  description String?
  baseStats   Json?   @map("base_stats") // shape varies per skill -> jsonb

  mech     Mech           @relation(fields: [mechId], references: [id], onDelete: Cascade)
  upgrades SkillUpgrade[]

  @@map("mech_skills")
}

model SkillUpgrade {
  id          String  @id @default(uuid()) @db.Uuid
  skillId     String  @map("skill_id") @db.Uuid
  // Self-reference: each upgrade may point at a parent upgrade in the SAME
  // table — that's how the branching tree is stored. Root nodes have
  // parentId = null. Prisma requires self-relations to be NAMED (the
  // "SkillUpgradeTree" label) so it can tell the two sides (parent vs
  // children) apart.
  parentId    String? @map("parent_id") @db.Uuid
  name        String
  description String?
  isEvolution Boolean @default(false) @map("is_evolution") // "evolve into..." nodes
  unlockReq   String? @map("unlock_req") // e.g. "3/8"

  skill    MechSkill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  parent   SkillUpgrade?  @relation("SkillUpgradeTree", fields: [parentId], references: [id])
  children SkillUpgrade[] @relation("SkillUpgradeTree")

  @@map("skill_upgrades")
}

// ---------- Traits (many-to-many via join table) ----------

model Trait {
  id    String  @id @default(uuid()) @db.Uuid
  name  String  @unique
  color String? // hex color for the tag chip in the UI

  mechs MechTrait[]

  @@map("traits")
}

model MechTrait {
  // Join table gets its own UUID id (instead of a composite PK) to stay
  // consistent with the "UUIDs for all primary keys" project convention.
  // The @@unique below still prevents duplicate mech<->trait pairs.
  id      String @id @default(uuid()) @db.Uuid
  mechId  String @map("mech_id") @db.Uuid
  traitId String @map("trait_id") @db.Uuid

  mech  Mech  @relation(fields: [mechId], references: [id], onDelete: Cascade)
  trait Trait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([mechId, traitId])
  @@map("mech_traits")
}

// ---------- Awakening (S-tier only) ----------

model AwakeningLevel {
  id            String  @id @default(uuid()) @db.Uuid
  mechId        String  @map("mech_id") @db.Uuid
  level         Int
  statBonus     Json?   @map("stat_bonus") // e.g. {"atk": 120, "hp": 800}
  specialEffect String? @map("special_effect")
  requirement   String? // e.g. "Shadow Warrior Shard x30"

  mech    Mech              @relation(fields: [mechId], references: [id], onDelete: Cascade)
  // "Exactly 5 nodes per level" is an app-level rule (enforced by the seed /
  // future admin code), not a DB constraint — kept simple by design.
  nodes   AwakeningNode[]
  unlocks AwakeningUnlock[]

  @@unique([mechId, level])
  @@map("awakening_levels")
}

model AwakeningNode {
  id        String @id @default(uuid()) @db.Uuid
  levelId   String @map("level_id") @db.Uuid
  position  Int // 1-5
  attribute String // e.g. "ATK", "Crit Rate"

  level AwakeningLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([levelId, position])
  @@map("awakening_nodes")
}

model AwakeningUnlock {
  id          String  @id @default(uuid()) @db.Uuid
  levelId     String  @map("level_id") @db.Uuid
  name        String
  description String?

  level AwakeningLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@map("awakening_unlocks")
}

// ---------- Unique weapon (S-tier only) + upgrade tree ----------

model Weapon {
  id          String  @id @default(uuid()) @db.Uuid
  // Nullable since Cycle G: a weapon can exist on its own; @unique keeps
  // "a mech owns at most one weapon". The owner is set from the admin.
  mechId      String? @unique @map("mech_id") @db.Uuid
  name        String
  description String?
  baseStats   Json?   @map("base_stats")
  // Weapons carry a type in the game too. Schema + API surface only for now —
  // the UI to assign it arrives with the future weapons editor.
  typeId String? @map("type_id") @db.Uuid
  type   Type?   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  // Weapons have their own S/Standard tier in the game — same values as
  // mech rank, so the enum is shared rather than duplicated.
  tier          MechRank @default(Standard)
  // Up to 7 rank-up preview lines (Lv.1-7); the cap is an app rule,
  // same pattern as pilots' bonus_per_level.
  rankUpPreview String[] @map("rank_up_preview")
  // Two art slots: image = the big weapon art, icon = the small square
  // (future list badges on the public site).
  imageUrl String? @map("image_url")
  iconUrl  String? @map("icon_url")

  mech        Mech?           @relation(fields: [mechId], references: [id], onDelete: Cascade)
  upgrades    WeaponUpgrade[]
  weaponSkins WeaponSkin[]
  helpers     Helper[]
  pilot       Pilot?
  skillNodes  SkillNode[]

  @@map("weapons")
}

model WeaponUpgrade {
  id          String  @id @default(uuid()) @db.Uuid
  weaponId    String  @map("weapon_id") @db.Uuid
  // Same self-referencing tree pattern as SkillUpgrade — see the comment there.
  parentId    String? @map("parent_id") @db.Uuid
  name        String
  description String?
  isEvolution Boolean @default(false) @map("is_evolution")
  unlockReq   String? @map("unlock_req")

  weapon   Weapon          @relation(fields: [weaponId], references: [id], onDelete: Cascade)
  parent   WeaponUpgrade?  @relation("WeaponUpgradeTree", fields: [parentId], references: [id])
  children WeaponUpgrade[] @relation("WeaponUpgradeTree")

  @@map("weapon_upgrades")
}

// ---------- Accessory (admin-managed since Cycle H) ----------

model Accessory {
  id String @id @default(uuid()) @db.Uuid
  // Nullable since Cycle H: Standard accessories are generic items; @unique
  // keeps "one accessory per mech" for the S-tier pairs. onDelete: SetNull —
  // a standalone accessory survives its mech (same reasoning as pilots).
  mechId String? @unique @map("mech_id") @db.Uuid
  name   String
  // Accessories share the Standard|S tier enum, like weapons.
  tier MechRank @default(Standard)
  // Attribute rows [{name, value}] — S: up to 2 rows, Standard: 1 (API rule).
  attributes Json @default("[]")
  // Only for mech-paired accessories — the API normalizes this to null
  // whenever the accessory has no mech. RENAMED from `description` in
  // Cycle H: the old free text (e.g. "Crit hits restore 1% HP") was
  // semantically an exclusive effect all along.
  exclusiveEffect String? @map("exclusive_effect")
  // Two art slots, like weapons: image = big art, icon = small square badge.
  imageUrl String? @map("image_url")
  iconUrl  String? @map("icon_url")

  mech Mech? @relation(fields: [mechId], references: [id], onDelete: SetNull)

  @@map("accessories")
}

// ---------- Skins ----------

model Skin {
  id          String  @id @default(uuid()) @db.Uuid
  // Skins are MECH-owned only since Cycle G — weapon skins live in their own
  // `weapon_skins` table because the two systems will diverge (future SS skins).
  mechId      String  @map("mech_id") @db.Uuid
  name        String
  description String?
  // Per-skin art, same slot the weapon_skins table got in Cycle G.1.
  imageUrl String? @map("image_url")

  mech   Mech       @relation(fields: [mechId], references: [id], onDelete: Cascade)
  stars  SkinStar[]

  @@map("skins")
}

model SkinStar {
  id     String @id @default(uuid()) @db.Uuid
  skinId String @map("skin_id") @db.Uuid
  star   Int // 1, 2, 3...
  perk   String // what this star level grants

  skin Skin @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@unique([skinId, star])
  @@map("skin_stars")
}

// ---------- Helpers ----------

model Helper {
  id            String  @id @default(uuid()) @db.Uuid
  // Same dual-nullable-FK pattern as Skin — see the comment there.
  mechId        String? @map("mech_id") @db.Uuid
  weaponId      String? @map("weapon_id") @db.Uuid
  name          String // e.g. "Darren", "Akira"
  passiveEffect String? @map("passive_effect")

  mech   Mech?        @relation(fields: [mechId], references: [id], onDelete: Cascade)
  weapon Weapon?      @relation(fields: [weaponId], references: [id], onDelete: Cascade)
  ranks  HelperRank[]

  @@map("helpers")
}

model HelperRank {
  id       String @id @default(uuid()) @db.Uuid
  helperId String @map("helper_id") @db.Uuid
  rank     Int
  effect   String

  helper Helper @relation(fields: [helperId], references: [id], onDelete: Cascade)

  @@unique([helperId, rank])
  @@map("helper_ranks")
}

// ---------- Users (Auth0 accounts) ----------

// Thin mirror of an Auth0 identity. Auth0 is the passport office (proves
// who someone is); this row is our membership card (what we display and
// what future builds/hearts join against). No passwords ever exist here.
model User {
  id       String  @id @default(uuid()) @db.Uuid
  // Auth0's stable subject, e.g. "google-oauth2|1180…" — the only link
  // between our world and Auth0's.
  auth0Sub String  @unique @map("auth0_sub")
  // The Auth0 display name (Google/Discord), captured from the SPA on the
  // first authenticated call and refreshed when it changes. Shown in the
  // admin Users list. Null until the user next signs in after this shipped.
  name     String?
  // Public display name. Null until chosen in Settings; required (app
  // rule) before creating builds. Unique site-wide.
  nickname String? @unique
  server   String? // game server, free text
  createdAt DateTime @default(now()) @map("created_at")

  builds      Build[]
  heartedBuilds BuildHeart[]

  @@map("users")
}

// ---------- Posted builds (public community feed) ----------

// A build the player chose to share. mechId/weaponId are stored as plain
// text (no FK) so deleting a mech from the wiki doesn't cascade-delete
// community builds — the same "degrades politely" principle as localStorage.
model Build {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  name        String
  description String  @default("")
  // The build targets a mech OR a single weapon — exactly one set (app rule).
  mechId   String?
  weaponId String? @map("weapon_id")
  // Skill / weapon picks, mirroring the localStorage BuildRecord shape.
  skillIds       String[] @map("skill_ids")
  weaponIds      String[] @map("weapon_ids")
  // Per-weapon skill picks: {"<weaponId>": ["<skillId>", ...]}
  weaponSkillIds Json     @default("{}") @map("weapon_skill_ids")
  // Publication state. New builds start as Draft (private); the public feed
  // and share pages only surface Published rows.
  status    BuildStatus @default(Draft)
  hearts    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  heartedBy BuildHeart[]

  @@map("builds")
}

// ---------- Build hearts (likes) ----------

// Join table: one row per (build, user) pair, preventing double-liking.
// The hearts Int counter on Build is kept in sync transactionally.
model BuildHeart {
  buildId String @map("build_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid

  build Build @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([buildId, userId])
  @@map("build_hearts")
}
